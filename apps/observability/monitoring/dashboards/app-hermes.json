      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"hermes-t\",container=\"hermes-t\"}[5m]))", "legendFormat": "hermes-t" },
